---
// Base layout. Semantic landmarks (header/nav/main/footer), a skip link, a
// lang attribute, and a sensible <title> — the floor every page stands on (§5).
import '../styles/global.css';
import { contentSecurityPolicy } from '../lib/security';
import { SETTINGS_COOKIE, parseSettings, settingsToRootAttrs } from '../lib/settings';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const siteName = 'Access Atlas';

// Apply the visitor's saved accessibility settings SERVER-SIDE (§5). The browsing
// pages are on-demand, so this reads the functional cookie on every request and
// stamps the class + CSS vars onto <html> below — zero client JS. On a
// prerendered page (build time) there is no request cookie, so this is just the
// defaults; that's why the pages that should honor settings set prerender=false.
const rootAttrs = settingsToRootAttrs(parseSettings(Astro.cookies.get(SETTINGS_COOKIE)?.value));

// Primary-nav "you are here" (§1: always show the current location). The active
// item gets aria-current="page" for assistive tech PLUS a visible style in
// global.css (persistent underline + bold — a shape/weight cue, never colour
// alone, WCAG 1.4.1). Zero client JS: we already have the request path here.
//
// Matching is PREFIX by default, so a section stays lit on its detail pages
// (/places/[id] keeps "Places" current). Trailing slash is normalised so
// "/places" and "/places/" resolve the same. Pages with no matching section
// (e.g. /contribute/confirm/…) simply light nothing — better than a wrong guess.
//
// "/about/" is the exception: it IS a prefix of /about/help/ and /about/privacy/,
// so under prefix matching it would light alongside them and emit two
// aria-current="page" nodes in one nav. It's marked `exact` for that reason —
// keep that flag if you add more pages under /about/.
const NAV = [
  { href: '/places/', label: 'Places' },
  { href: '/providers/', label: 'Providers' },
  { href: '/contribute/submit/', label: 'Suggest a listing' },
  { href: '/about/', label: 'About', exact: true },
  { href: '/about/help/', label: 'Help' },
  { href: '/settings/', label: 'Accessibility' },
  { href: '/about/privacy/', label: 'Privacy' },
];
const herePath = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const isCurrent = (href: string, exact = false): boolean =>
  exact ? herePath === href : herePath.startsWith(href);
---

<!doctype html>
<html lang="en" class={rootAttrs.class || undefined} style={rootAttrs.style}>
  <head>
    <meta charset="utf-8" />
    <!-- viewport-fit=cover is REQUIRED for env(safe-area-inset-*) to resolve to
         anything but 0 (see global.css safe-area block). Without it the iOS
         status-bar / notch overlap fix below is silently inert. -->
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <!--
      Content-Security-Policy baked into the page so it protects prerendered
      static pages regardless of host (hosting is still open, §13). SSR routes
      ALSO get it as a real HTTP header via src/middleware.ts. `script-src 'none'`
      keeps the zero-JS non-negotiable self-enforcing (§2/§5) — EXCEPT on the two
      list routes, which relax to `script-src 'self'` for the /nearby.js
      enhancement (route-aware; see src/lib/security.ts + the ADR). The meta must
      match the header per route, or the browser's intersection would block the
      script. One source of truth: src/lib/security.ts.
    -->
    <meta http-equiv="Content-Security-Policy" content={contentSecurityPolicy(Astro.url.pathname)} />
    <!-- Self-hosted SVG favicon (CSP img-src 'self'); no external request. -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title} — {siteName}</title>
    {description && <meta name="description" content={description} />}
    <!-- No third-party trackers, ever (§6, §14). No analytics phone-home. -->
  </head>
  <body>
    <!-- First focusable element: keyboard users skip straight to content (§5). -->
    <a href="#main" class="skip-link">Skip to main content</a>

    <header class="site">
      <div class="container">
        <a href="/" aria-label={`${siteName} — home`}>
          {/* Brand mark — decorative (the wordmark names the site), so hidden
              from assistive tech. currentColor => white on the teal header. An
              inclusive compass/atlas motif, NOT the wheelchair symbol (§3). */}
          <svg class="brand-mark" viewBox="0 0 32 32" aria-hidden="true" focusable="false">
            <circle cx="16" cy="16" r="13" fill="none" stroke="currentColor" stroke-opacity="0.5" stroke-width="2" />
            <path d="M16 4 L18.8 13.2 L28 16 L18.8 18.8 L16 28 L13.2 18.8 L4 16 L13.2 13.2 Z" fill="currentColor" />
          </svg>
          <strong>{siteName}</strong>
        </a>
        <nav aria-label="Primary">
          <ul>
            {NAV.map(({ href, label, exact }) => (
              <li>
                <a href={href} aria-current={isCurrent(href, exact) ? 'page' : undefined}>{label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main id="main" class="container" tabindex="-1">
      <slot />
    </main>

    <footer class="site">
      <div class="container">
        <p>
          Accessibility tools built <em>with</em> the community, not sold
          <em>to</em> it. Listings are self-reported and community-sourced —
          see <a href="/about/privacy/">how we label trust</a>.
        </p>
        <p class="footer-links">
          <a href="/about/">About</a> ·
          <a href="/about/help/">Help &amp; plain words</a> ·
          <a href="/settings/">Accessibility settings</a> ·
          <a href="/about/accessibility/">Accessibility statement</a> ·
          <a href="/account/">Your data</a>
        </p>
      </div>
    </footer>
  </body>
</html>
