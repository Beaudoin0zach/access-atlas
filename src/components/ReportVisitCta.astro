---
// A prominent, honest entry point into the community-validation layer (§4 — the
// moat). The confirm flow is per-attribute (one claim at a time), so this CTA
// signposts down to the attribute list, where each claim carries its own
// "Report your visit" link. It never implies the listing is verified — reporting
// a visit adds YOUR first-person report; a claim only flips once enough
// independent visits agree (§4 honest labeling). Zero-JS: a plain anchor.
interface Props {
  /** Fragment where the per-attribute confirm links live (the accessibility
      section heading). */
  target: string;
  /** Only worth showing when there are claims to confirm. */
  hasClaims: boolean;
}
const { target, hasClaims } = Astro.props;
---
{
  hasClaims && (
    <aside class="report-cta" aria-label="Report your visit">
      <h2 class="report-cta-title">Been here? Report your visit</h2>
      <p>
        Add your own first-person report on any accessibility claim below. Answer
        from what you actually experienced — that's how the community validates a
        listing. Your report doesn't mark this listing “verified”; it counts
        toward a claim only once enough independent visits agree.
      </p>
      <a class="btn btn-primary" href={target}>Report a visit</a>
    </aside>
  )
}
