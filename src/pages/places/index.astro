---
// On-demand so newly submitted places appear immediately. Zero-JS.
export const prerender = false;

import Base from '../../layouts/Base.astro';
import ListingCard from '../../components/ListingCard.astro';
import ListingFilters from '../../components/ListingFilters.astro';
import ListingEmptyState from '../../components/ListingEmptyState.astro';
import { getListings } from '../../lib/repo';
import {
  applyListingFilters,
  countyOptions,
  hasActiveFilters,
  parseListingFilters,
  sortListings,
} from '../../lib/filters';

const places = await getListings('place');
const filters = parseListingFilters(Astro.url.searchParams);
const active = hasActiveFilters(filters, 'place');
// Filter first (if any), then sort — sorting always applies (a bare ?sort=zip
// reorders the full list without "narrowing" it).
const shown = sortListings(active ? applyListingFilters(places, filters) : places, filters.sort);
---

<Base title="Places" description="Accessible businesses and physical spaces.">
  <h1>Accessible places</h1>
  <p>
    {places.length} {places.length === 1 ? 'place' : 'places'} listed. This list
    is the primary interface — no map required. (A map may be added later as a
    progressive enhancement over this same list.)
  </p>
  <p><a href="/contribute/submit/?kind=place">+ Suggest a place</a></p>

  <ListingFilters
    kind="place"
    filters={filters}
    counties={countyOptions(places)}
    active={active}
    action="/places/"
  />

  {/* A real <h2> introduces the results region so the heading outline is
      h1 → h2 → h3 (not h1 → h3), and screen-reader users can jump straight to
      the result count via headings navigation after a filter reload. Visible
      and carrying the count when filtering; present-but-sr-only otherwise so
      the default view stays clean (§5). */}
  <h2 class:list={['results-heading', { 'sr-only': !active }]}>
    {active
      ? `${shown.length} of ${places.length} ${places.length === 1 ? 'place matches' : 'places match'} your filters`
      : `All ${places.length} ${places.length === 1 ? 'place' : 'places'}`}
  </h2>

  {
    shown.length === 0 ? (
      <ListingEmptyState
        kind="place"
        action="/places/"
        active={active}
        listings={places}
        filters={filters}
      />
    ) : (
      <ul class="listing-list">
        {shown.map((listing) => (
          <ListingCard listing={listing} />
        ))}
      </ul>
    )
  }

  {/* Progressive enhancement ONLY (§5/§13): the page above is fully usable with
      no JS. This one self-hosted script adds on-device "sort by distance" — the
      visitor's location never leaves the device (§6). Scoped script-src 'self'
      carve-out lives in src/lib/security.ts. is:inline keeps Astro from bundling
      the public asset. */}
  <script src="/nearby.js" is:inline defer></script>
</Base>
