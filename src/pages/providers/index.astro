---
// On-demand so newly submitted providers appear immediately. Zero-JS.
export const prerender = false;

import Base from '../../layouts/Base.astro';
import ListingCard from '../../components/ListingCard.astro';
import ListingFilters from '../../components/ListingFilters.astro';
import ListingEmptyState from '../../components/ListingEmptyState.astro';
import { getListings } from '../../lib/repo';
import {
  applyListingFilters,
  countyOptions,
  hasActiveFilters,
  parseListingFilters,
  sortListings,
} from '../../lib/filters';

const providers = await getListings('provider');
const filters = parseListingFilters(Astro.url.searchParams);
const active = hasActiveFilters(filters, 'provider');
// Filter first (if any), then sort — sorting always applies.
const shown = sortListings(active ? applyListingFilters(providers, filters) : providers, filters.sort);
---

<Base
  title="Providers"
  description="Disability-competent and disabled-owned or disabled-led providers."
>
  <h1>Providers</h1>
  <p>
    Two things matter here, tracked separately: whether a provider is
    <strong>disability-literate</strong> (serves disabled people well) and
    whether they are <strong>disabled-owned or disabled-led</strong>. A provider
    may be either, both, or neither — we never merge the two.
  </p>
  <p><a href="/contribute/submit/?kind=provider">+ Suggest a provider</a></p>

  <ListingFilters
    kind="provider"
    filters={filters}
    counties={countyOptions(providers)}
    active={active}
    action="/providers/"
  />

  {/* A real <h2> introduces the results region so the heading outline is
      h1 → h2 → h3 (not h1 → h3), and screen-reader users can jump straight to
      the result count via headings navigation after a filter reload. Visible
      and carrying the count when filtering; present-but-sr-only otherwise so
      the default view stays clean (§5). */}
  <h2 class:list={['results-heading', { 'sr-only': !active }]}>
    {active
      ? `${shown.length} of ${providers.length} ${providers.length === 1 ? 'provider matches' : 'providers match'} your filters`
      : `All ${providers.length} ${providers.length === 1 ? 'provider' : 'providers'}`}
  </h2>

  {
    shown.length === 0 ? (
      <ListingEmptyState
        kind="provider"
        action="/providers/"
        active={active}
        listings={providers}
        filters={filters}
      />
    ) : (
      <ul class="listing-list">
        {shown.map((listing) => (
          <ListingCard listing={listing} />
        ))}
      </ul>
    )
  }

  {/* Progressive enhancement ONLY (§5/§13): the page above is fully usable with
      no JS. This one self-hosted script adds on-device "sort by distance" — the
      visitor's location never leaves the device (§6). Scoped script-src 'self'
      carve-out lives in src/lib/security.ts. is:inline keeps Astro from bundling
      the public asset. */}
  <script src="/nearby.js" is:inline defer></script>
</Base>
