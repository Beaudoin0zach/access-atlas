# Copy to .env and fill in. NEVER commit .env (§6: no secrets in the repo).
#
# The app renders from a local seed fallback when these are unset, so you can
# run and a11y-test the skeleton with zero backend. Set them to read real data
# from Postgres/Supabase.
#
# Local Supabase (via `npm run db:start`) prints these values on startup.

# Public origin(s) this app is served from — for Astro's CSRF origin check.
# BUILD-TIME: baked into the server manifest by astro.config.mjs, so on DO App
# Platform it must be a BUILD-time env var (present during `npm run build`), not
# only a run-time one. Comma-separated; full origins or bare hosts. Leave UNSET
# for local dev (the dev server skips this validation). Set it in production or
# every form POST 403s with "Cross-site POST form submissions are forbidden" —
# the TLS-terminating proxy forwards the real host in X-Forwarded-Host and Astro
# only trusts that host when it is named here.
#   SITE_ORIGINS=https://accessatlas.org,access-atlas-xxxx.ondigitalocean.app
SITE_ORIGINS=

# Public — safe to expose to the browser (anon key is RLS-gated, §6).
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the client. The contributions endpoint writes
# with this (bypasses RLS) until Keycloak-backed contributor auth lands.
SUPABASE_SERVICE_ROLE_KEY=

# Contribution write-gate. The confirmations endpoint REFUSES to save anything
# unless this is exactly 'true'. It's a safety interlock so an unauthenticated
# write endpoint can't ship by accident (there's no real auth yet — Keycloak is
# still Phase 0). Set to 'true' ONLY for local dev / preview. NEVER in production.
ALLOW_PROVISIONAL_CONTRIBUTIONS=

# Keycloak OIDC (server-only). Leave UNSET until the platform IdP is stood up and
# an Access Atlas client is registered — the app falls back to the provisional
# gate above. Set ALL THREE together to switch contribution to real auth:
#   - KEYCLOAK_ISSUER: the realm issuer, e.g. https://id.example/realms/bas
#   - KEYCLOAK_CLIENT_ID: the public (PKCE) client id registered for this app
#   - KEYCLOAK_REDIRECT_URI: this app's callback, e.g. https://app/api/auth/callback
KEYCLOAK_ISSUER=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_REDIRECT_URI=
