{
  "name": "access-directory",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Access Atlas — a disability-focused discovery platform: accessible providers, accessible places, community validation.",
  "engines": {
    "node": ">=20.3.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "astro check",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:a11y": "playwright test",
    "db:start": "npx supabase start",
    "db:reset": "npx supabase db reset",
    "db:stop": "npx supabase stop",
    "migrate:deploy": "sh scripts/migrate-deploy.sh",
    "migrate:check": "sh scripts/migrate-deploy.sh --dry-run",
    "seed:import": "node scripts/seed-import.mjs",
    "data-rights": "node scripts/data-rights.mjs",
    "moderate:photo": "node scripts/moderate-photo.mjs",
    "moderate:takedown": "node scripts/takedown-confirmation.mjs"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.5",
    "@astrojs/react": "^4.2.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@supabase/supabase-js": "^2.45.0",
    "astro": "^5.2.0",
    "jose": "^5.10.0",
    "react": "^18.3.1",
    "react-aria-components": "^1.5.0",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
